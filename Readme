CREATE TABLE hep_exercises (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  name text NOT NULL,
  image_url text NOT NULL,
  keywords text[] NOT NULL DEFAULT '{}',
  instructions text NOT NULL DEFAULT '',
  date_added timestamptz NOT NULL DEFAULT now(),
  added_by text NOT NULL
);

-- Allow all authenticated users to read
CREATE POLICY "authenticated can read exercises"
ON hep_exercises FOR SELECT
TO authenticated
USING (true);

-- Only super admins can insert
CREATE POLICY "super admins can insert exercises"
ON hep_exercises FOR INSERT
TO authenticated
WITH CHECK (
  EXISTS (
    SELECT 1 FROM profiles
    WHERE id = auth.uid()
    AND is_super_admin = true
  )
);

ALTER TABLE hep_exercises ENABLE ROW LEVEL SECURITY;
